{
  "name": "app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "sass": "sass --watch public/scss:public/css --source-map",
    "build-css": "postcss public/scss/main.scss -o public/css/main.css --syntax postcss-scss --map",
    "build-js": "esbuild public/js/main.js --bundle --outfile=public/js/bundle.js --sourcemap",
    "start": "node app.js",
    "dev": "node --watch app.js",
    "dev:browser": "browser-sync start --proxy 'localhost:3100' --files 'public/**/*, views/**/*'",
    "deploy": "basic-ftp -u $FTP_USER -p $FTP_PASS -h $FTP_HOST -r /public public/"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.13.6",
    "body-parser": "^2.2.2",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "moment": "^2.30.1",
    "path": "^0.12.7",
    "pug": "^3.0.2",
    "qs": "^6.15.0",
    "sass": "^1.77.8",
    "strapi-plugin-populate-deep": "^3.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "basic-ftp": "^5.2.0",
    "browser-sync": "^3.0.4",
    "esbuild": "^0.27.4",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-scss": "^4.0.9",
    "tailwindcss": "^4.2.2"
  }
}
